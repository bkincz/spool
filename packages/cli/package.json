{
	"name": "@bkincz/spool",
	"version": "1.4.0",
	"description": "spool CLI: create, configure and maintain micro frontends",
	"type": "module",
	"keywords": [
		"micro-frontends",
		"module-federation",
		"vite",
		"react",
		"cli",
		"scaffolding",
		"monorepo"
	],
	"author": "Benjamin Kinczel <beni.kinczel@gmail.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/bkincz/spool.git"
	},
	"bugs": {
		"url": "https://github.com/bkincz/spool/issues"
	},
	"homepage": "https://github.com/bkincz/spool#readme",
	"bin": {
		"spool": "./dist/index.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"prepublishOnly": "node -e \"const f=require('fs');f.copyFileSync('../../README.md','README.md');f.copyFileSync('../../LICENSE','LICENSE')\" && pnpm run build && pnpm run type-check && pnpm run test:run",
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"start": "node ./dist/index.js",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"dependencies": {
		"@clack/prompts": "^0.7.0",
		"commander": "^12.1.0",
		"cross-spawn": "^7.0.6",
		"picocolors": "^1.1.1",
		"prettier": "^3.8.4",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/cross-spawn": "^6.0.6",
		"@types/node": "^22.9.0",
		"@vitest/coverage-v8": "^3.2.4",
		"esbuild": "^0.28.1",
		"tsup": "^8.3.5",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
