{
	"name": "@spool/cli",
	"version": "0.1.0",
	"description": "spool CLI — create, configure and maintain micro frontends",
	"type": "module",
	"author": "Benjamin Kinczel <beni.kinczel@gmail.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/bkincz/spool.git"
	},
	"bin": {
		"spool": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"start": "node ./dist/index.js",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@clack/prompts": "^0.7.0",
		"commander": "^12.1.0",
		"cross-spawn": "^7.0.6",
		"picocolors": "^1.1.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/cross-spawn": "^6.0.6",
		"@types/node": "^22.9.0",
		"@vitest/coverage-v8": "^3.2.4",
		"tsup": "^8.3.5",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
